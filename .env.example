# --- LLM ---
# LiteLLM provider string. Swap providers/models with this one line.
# quality-first default: openai/gpt-5.5 ; cheaper A-B target: openai/gpt-5.4-mini
TRANSCLASSIFY_MODEL=openai/gpt-5.5
OPENAI_API_KEY=sk-...

# --- SERP (enrichment). Leave blank to disable web lookup (enrich still categorizes). ---
SERPER_API_KEY=

# --- Database (optional; logging only). Matches docker-compose. ---
DATABASE_URL=postgresql+psycopg://transclassify:transclassify@localhost:5432/transclassify

# --- CORS (frontend dev server) ---
CORS_ORIGINS=http://localhost:5173
